#!/usr/bin/env bash
#
# pre-push hook: refuse to push directly to the protected branch.
#
# Pushes should reach 'main' only through a reviewed pull request, never by
# pushing the local 'main' straight to origin. This hook blocks that mistake
# locally, before anything leaves your machine.
#
# Install once per clone:   git config core.hooksPath .githooks
# Bypass intentionally:     git push --no-verify   (use sparingly)

protected_branch="main"

# stdin gives: <local ref> <local sha> <remote ref> <remote sha>
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/$protected_branch" ]; then
    echo "✋ Blocked: direct push to '$protected_branch' is not allowed." >&2
    echo "   Open a pull request instead:" >&2
    echo "     git checkout -b your-feature" >&2
    echo "     git push -u origin your-feature" >&2
    echo "     gh pr create --base $protected_branch --fill" >&2
    echo "   (Override with 'git push --no-verify' only if you really mean it.)" >&2
    exit 1
  fi
done

exit 0
